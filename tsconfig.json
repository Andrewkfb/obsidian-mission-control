{
	"extends": "@tsconfig/svelte/tsconfig.json",
	"compilerOptions": {
		"baseUrl": ".",
		"module": "ESNext",
		"target": "ES2018",
		"allowJs": true,
		"moduleResolution": "node",
		"importHelpers": true,
		"esModuleInterop": true,
		"lib": ["DOM", "ES5", "ES6", "ES7", "ES2018", "ES2021"]
	},
	"include": ["src/**/*.ts", "src/**/*.svelte", "src/**/*.d.ts"]
}
